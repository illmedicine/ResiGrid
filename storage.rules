rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    // Listing / property photos: owner can upload, anyone can view.
    match /properties/{propertyId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn() &&
        firestore.get(/databases/(default)/documents/properties/$(propertyId)).data.ownerId == request.auth.uid;
    }

    // Maintenance request photos: only the submitting tenant and the
    // owning property manager (verified server-side) can read/write.
    match /maintenance/{requestId}/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    // Lease documents: locked down, served via signed URLs generated by
    // Cloud Functions rather than direct client access.
    match /leases/{leaseId}/{allPaths=**} {
      allow read, write: if false;
    }
  }
}
