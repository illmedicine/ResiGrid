rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isSelf(uid) { return isSignedIn() && request.auth.uid == uid; }
    function myUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isTeamMemberFor(ownerUid) {
      return isSignedIn() && myUserDoc().get('teamAdminId', null) == ownerUid;
    }
    function canAccessProperty(propOwnerId, propId) {
      return isSignedIn() && (
        request.auth.uid == propOwnerId ||
        (myUserDoc().get('teamAdminId', null) == propOwnerId &&
         myUserDoc().get('teamPropertyIds', []).hasAny([propId]))
      );
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSelf(uid);
      allow update: if isSelf(uid) && (
        request.resource.data.role == resource.data.role ||
        (request.resource.data.get('teamAdminId', null) != null &&
         request.resource.data.role == 'property_manager')
      );
      allow delete: if false;
    }

    match /propertyManagers/{uid} {
      allow read: if isSignedIn();
      allow write: if isSelf(uid);
    }

    match /properties/{propertyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        request.resource.data.ownerId == request.auth.uid ||
        isTeamMemberFor(request.resource.data.ownerId)
      );
      allow update: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid ||
        canAccessProperty(resource.data.ownerId, propertyId)
      );
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    match /units/{unitId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.propertyId != null;
      allow update, delete: if isSignedIn();
    }

    match /listings/{listingId} {
      allow read: if resource.data.status == 'published' || isSignedIn();
      allow create: if isSignedIn() && (
        request.resource.data.ownerId == request.auth.uid ||
        isTeamMemberFor(request.resource.data.ownerId)
      );
      allow update, delete: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid ||
        isTeamMemberFor(resource.data.ownerId)
      );
    }

    match /applications/{applicationId} {
      allow read: if isSignedIn() && (
        resource.data.tenantId == request.auth.uid ||
        resource.data.pmId == request.auth.uid ||
        isTeamMemberFor(resource.data.pmId) ||
        get(/databases/$(database)/documents/listings/$(resource.data.listingId)).data.ownerId == request.auth.uid
      );
      allow create: if isSignedIn() && (
        request.resource.data.tenantId == request.auth.uid ||
        request.resource.data.pmId == request.auth.uid ||
        isTeamMemberFor(request.resource.data.pmId)
      );
      allow update: if isSignedIn() && (
        resource.data.tenantId == request.auth.uid ||
        resource.data.pmId == request.auth.uid ||
        isTeamMemberFor(resource.data.pmId) ||
        get(/databases/$(database)/documents/listings/$(resource.data.listingId)).data.ownerId == request.auth.uid
      );
      allow delete: if isSignedIn() && (
        resource.data.pmId == request.auth.uid ||
        isTeamMemberFor(resource.data.pmId)
      );
    }

    match /tenantInterests/{interestId} {
      allow read: if isSignedIn() && (
        resource.data.tenantId == request.auth.uid ||
        resource.data.pmId == request.auth.uid ||
        isTeamMemberFor(resource.data.pmId)
      );
      allow create: if isSignedIn() && request.resource.data.tenantId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.tenantId == request.auth.uid ||
        resource.data.pmId == request.auth.uid ||
        isTeamMemberFor(resource.data.pmId)
      );
      allow delete: if false;
    }

    match /applicationForms/{formId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        request.resource.data.pmId == request.auth.uid ||
        isTeamMemberFor(request.resource.data.pmId)
      );
      allow update, delete: if isSignedIn() && (
        resource.data.pmId == request.auth.uid ||
        isTeamMemberFor(resource.data.pmId)
      );
    }

    match /leases/{leaseId} {
      allow read: if isSignedIn() && (
        resource.data.tenantId == request.auth.uid ||
        resource.data.pmId == request.auth.uid ||
        isTeamMemberFor(resource.data.pmId)
      );
      allow create: if isSignedIn() && (
        request.resource.data.pmId == request.auth.uid ||
        isTeamMemberFor(request.resource.data.pmId)
      );
      allow update: if isSignedIn() && (
        resource.data.tenantId == request.auth.uid ||
        resource.data.pmId == request.auth.uid ||
        isTeamMemberFor(resource.data.pmId)
      );
      allow delete: if isSignedIn() && (
        resource.data.pmId == request.auth.uid ||
        isTeamMemberFor(resource.data.pmId)
      );
    }

    match /payments/{paymentId} {
      allow read: if isSignedIn() && (
        resource.data.tenantId == request.auth.uid ||
        resource.data.pmId == request.auth.uid ||
        isTeamMemberFor(resource.data.pmId)
      );
      allow write: if false;
    }

    match /rentInvoices/{invoiceId} {
      allow read: if isSignedIn() && (
        resource.data.tenantId == request.auth.uid ||
        resource.data.pmId == request.auth.uid ||
        isTeamMemberFor(resource.data.pmId)
      );
      allow write: if false;
    }

    match /vouchers/{voucherId} {
      allow read: if isSignedIn() && (
        resource.data.senderId == request.auth.uid ||
        resource.data.recipientUserId == request.auth.uid
      );
      allow write: if false;
    }

    match /reputationScores/{tenantId} {
      allow read: if isSignedIn();
      allow write: if isSelf(tenantId);
    }

    match /maintenanceRequests/{requestId} {
      allow read: if isSignedIn() && (
        resource.data.tenantId == request.auth.uid ||
        resource.data.pmId == request.auth.uid ||
        isTeamMemberFor(resource.data.pmId) ||
        get(/databases/$(database)/documents/properties/$(resource.data.propertyId)).data.ownerId == request.auth.uid ||
        canAccessProperty(
          get(/databases/$(database)/documents/properties/$(resource.data.propertyId)).data.ownerId,
          resource.data.propertyId
        )
      );
      allow create: if isSignedIn() && request.resource.data.tenantId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.tenantId == request.auth.uid ||
        get(/databases/$(database)/documents/properties/$(resource.data.propertyId)).data.ownerId == request.auth.uid ||
        canAccessProperty(
          get(/databases/$(database)/documents/properties/$(resource.data.propertyId)).data.ownerId,
          resource.data.propertyId
        )
      );
      allow delete: if false;
      match /messages/{messageId} {
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/maintenanceRequests/$(requestId)).data.tenantId == request.auth.uid ||
          get(/databases/$(database)/documents/maintenanceRequests/$(requestId)).data.pmId == request.auth.uid ||
          isTeamMemberFor(get(/databases/$(database)/documents/maintenanceRequests/$(requestId)).data.pmId)
        );
        allow create: if isSignedIn() &&
          request.resource.data.senderId == request.auth.uid && (
            get(/databases/$(database)/documents/maintenanceRequests/$(requestId)).data.tenantId == request.auth.uid ||
            get(/databases/$(database)/documents/maintenanceRequests/$(requestId)).data.pmId == request.auth.uid ||
            isTeamMemberFor(get(/databases/$(database)/documents/maintenanceRequests/$(requestId)).data.pmId)
          );
        allow update, delete: if false;
      }
    }

    match /messageThreads/{threadId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participantIds;
      allow update: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      allow delete: if false;
      match /messages/{messageId} {
        allow read, create: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/messageThreads/$(threadId)).data.participantIds;
        allow update, delete: if false;
      }
    }

    match /pmTeamInvites/{inviteId} {
      allow read: if isSignedIn() && (
        resource.data.adminId == request.auth.uid ||
        resource.data.email == request.auth.token.email ||
        resource.data.memberId == request.auth.uid
      );
      allow create: if isSignedIn() && request.resource.data.adminId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.adminId == request.auth.uid ||
        resource.data.email == request.auth.token.email
      );
      allow delete: if false;
    }

    match /platformStats/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /uniqueLogins/{uid} { allow read, write: if isSelf(uid); }
    match /nationalListings/{listingId} { allow read: if true; allow write: if false; }
    match /systemConfig/{docId} { allow read: if true; allow write: if false; }
    match /squareConnections/{uid} { allow read, write: if false; }

    match /pmSubscriptions/{uid} {
      allow read: if isSelf(uid) || isTeamMemberFor(uid);
      allow write: if false;
    }

    match /notices/{noticeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        request.resource.data.pmId == request.auth.uid ||
        isTeamMemberFor(request.resource.data.pmId)
      );
      allow update: if isSignedIn() && (
        resource.data.pmId == request.auth.uid ||
        isTeamMemberFor(resource.data.pmId) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy'])
      );
      allow delete: if isSignedIn() && (
        resource.data.pmId == request.auth.uid ||
        isTeamMemberFor(resource.data.pmId)
      );
    }

    match /leaseTerms/{leaseId} {
      allow read: if isSignedIn() && (
        resource.data.pmId == request.auth.uid ||
        resource.data.tenantId == request.auth.uid ||
        isTeamMemberFor(resource.data.pmId)
      );
      allow create: if isSignedIn() && (
        request.resource.data.pmId == request.auth.uid ||
        isTeamMemberFor(request.resource.data.pmId)
      );
      allow update: if isSignedIn() && (
        resource.data.pmId == request.auth.uid ||
        resource.data.tenantId == request.auth.uid ||
        isTeamMemberFor(resource.data.pmId)
      );
      allow delete: if isSignedIn() && (
        resource.data.pmId == request.auth.uid ||
        isTeamMemberFor(resource.data.pmId)
      );
    }

    match /leaseTemplates/{templateId} {
      allow read: if isSignedIn() && (
        resource.data.pmId == request.auth.uid ||
        isTeamMemberFor(resource.data.pmId)
      );
      allow create: if isSignedIn() && (
        request.resource.data.pmId == request.auth.uid ||
        isTeamMemberFor(request.resource.data.pmId)
      );
      allow update, delete: if isSignedIn() && (
        resource.data.pmId == request.auth.uid ||
        isTeamMemberFor(resource.data.pmId)
      );
    }

    match /paymentReviews/{paymentId} {
      allow read: if isSignedIn() && (
        resource.data.tenantId == request.auth.uid ||
        resource.data.pmId == request.auth.uid ||
        isTeamMemberFor(resource.data.pmId)
      );
      allow create: if isSignedIn() && request.resource.data.tenantId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.tenantId == request.auth.uid ||
        resource.data.pmId == request.auth.uid ||
        isTeamMemberFor(resource.data.pmId)
      );
      allow delete: if false;
    }

    match /sharedDocuments/{docId} {
      allow read: if isSignedIn() && (
        resource.data.tenantId == request.auth.uid ||
        resource.data.pmId == request.auth.uid ||
        isTeamMemberFor(resource.data.pmId)
      );
      allow create: if isSignedIn() && request.resource.data.uploaderId == request.auth.uid;
      allow delete: if isSignedIn() && (
        resource.data.uploaderId == request.auth.uid ||
        resource.data.pmId == request.auth.uid ||
        isTeamMemberFor(resource.data.pmId)
      );
      allow update: if false;
    }
  }
}
