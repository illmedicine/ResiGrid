rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    // Listing photos — any signed-in property manager can upload;
    // photos are publicly readable for the listings browser.
    match /listings/{listingId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Property / general photos — publicly readable, PM writes only.
    match /properties/{propertyId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Maintenance request photos — signed-in users only.
    match /maintenance/{requestId}/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    // Lease documents — locked down; served via signed URLs from Cloud Functions.
    match /leases/{leaseId}/{allPaths=**} {
      allow read, write: if false;
    }
  }
}
