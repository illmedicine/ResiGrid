rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // --- Users ---
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSelf(uid);
      allow update: if isSelf(uid) && request.resource.data.role == resource.data.role;
      allow delete: if false;
    }

    // --- Property managers ---
    match /propertyManagers/{uid} {
      allow read: if isSignedIn();
      allow write: if isSelf(uid);
    }

    // --- Properties ---
    // Any signed-in user can read (tenants need to read their own property details/photos).
    // Only the owner can mutate.
    match /properties/{propertyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    // --- Units ---
    match /units/{unitId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.propertyId != null;
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // --- Listings ---
    // Published listings are public. Any signed-in user can read all listings
    // (tenants need to read their unit's listing even when status is "filled").
    match /listings/{listingId} {
      allow read: if resource.data.status == 'published' || isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    // --- Applications ---
    // Tenant reads own; PM reads/updates via pmId or listing ownership.
    // PM can create (shortlist/invite); tenant updates with docs/answers.
    match /applications/{applicationId} {
      allow read: if isSignedIn() &&
        (resource.data.tenantId == request.auth.uid ||
         resource.data.pmId == request.auth.uid ||
         get(/databases/$(database)/documents/listings/$(resource.data.listingId)).data.ownerId == request.auth.uid);
      allow create: if isSignedIn() && (
        request.resource.data.tenantId == request.auth.uid ||
        request.resource.data.pmId == request.auth.uid
      );
      allow update: if isSignedIn() &&
        (resource.data.tenantId == request.auth.uid ||
         resource.data.pmId == request.auth.uid ||
         get(/databases/$(database)/documents/listings/$(resource.data.listingId)).data.ownerId == request.auth.uid);
      allow delete: if false;
    }

    // --- Tenant interests (express interest / schedule visit) ---
    match /tenantInterests/{interestId} {
      allow read: if isSignedIn() &&
        (resource.data.tenantId == request.auth.uid ||
         resource.data.pmId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.tenantId == request.auth.uid;
      allow update: if isSignedIn() &&
        (resource.data.tenantId == request.auth.uid ||
         resource.data.pmId == request.auth.uid);
      allow delete: if false;
    }

    // --- Application forms (PM-created custom forms) ---
    match /applicationForms/{formId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.pmId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.pmId == request.auth.uid;
    }

    // --- Leases ---
    match /leases/{leaseId} {
      allow read: if isSignedIn() &&
        (resource.data.tenantId == request.auth.uid || resource.data.pmId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.pmId == request.auth.uid;
      allow update: if isSignedIn() &&
        (resource.data.tenantId == request.auth.uid || resource.data.pmId == request.auth.uid);
      allow delete: if isSignedIn() && resource.data.pmId == request.auth.uid;
    }

    // --- Payments (written only by Cloud Functions via admin SDK) ---
    match /payments/{paymentId} {
      allow read: if isSignedIn() &&
        (resource.data.tenantId == request.auth.uid ||
         resource.data.pmId == request.auth.uid);
      allow write: if false;
    }

    // --- Vouchers (written only by Cloud Functions via admin SDK) ---
    match /vouchers/{voucherId} {
      allow read: if isSignedIn() &&
        (resource.data.senderId == request.auth.uid || resource.data.recipientUserId == request.auth.uid);
      allow write: if false;
    }

    // --- Reputation scores ---
    // Cloud Functions handle payment-based scoring. Tenants can write to their
    // own doc to bootstrap the resident badge when first loading the dashboard.
    match /reputationScores/{tenantId} {
      allow read: if isSignedIn();
      allow write: if isSelf(tenantId);
    }

    // --- Maintenance requests ---
    // Tenant reads/creates own; PM reads/updates for their properties
    match /maintenanceRequests/{requestId} {
      allow read: if isSignedIn() &&
        (resource.data.tenantId == request.auth.uid ||
         get(/databases/$(database)/documents/properties/$(resource.data.propertyId)).data.ownerId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.tenantId == request.auth.uid;
      allow update: if isSignedIn() &&
        (resource.data.tenantId == request.auth.uid ||
         get(/databases/$(database)/documents/properties/$(resource.data.propertyId)).data.ownerId == request.auth.uid);
      allow delete: if false;
    }

    // --- Message threads ---
    match /messageThreads/{threadId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participantIds;
      allow update: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      allow delete: if false;

      match /messages/{messageId} {
        allow read, create: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/messageThreads/$(threadId)).data.participantIds;
        allow update, delete: if false;
      }
    }

    // --- Platform stats (easter egg login counter — publicly readable) ---
    match /platformStats/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // --- Unique login registry (one doc per uid, written by that user only) ---
    match /uniqueLogins/{uid} {
      allow read, write: if isSelf(uid);
    }

    // --- Square OAuth connections (server-only; Cloud Functions via admin SDK) ---
    match /squareConnections/{uid} {
      allow read, write: if false;
    }

    // --- PM Subscriptions (write by Cloud Functions only; read by owner) ---
    match /pmSubscriptions/{uid} {
      allow read: if isSelf(uid);
      allow write: if false;
    }

    // --- Notices ---
    match /notices/{noticeId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn() && request.resource.data.pmId == request.auth.uid;
    }

    // --- Lease terms (full detailed lease documents) ---
    match /leaseTerms/{leaseId} {
      allow read: if isSignedIn() &&
        (resource.data.pmId == request.auth.uid || resource.data.tenantId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.pmId == request.auth.uid;
      allow update: if isSignedIn() &&
        (resource.data.pmId == request.auth.uid || resource.data.tenantId == request.auth.uid);
      allow delete: if isSignedIn() && resource.data.pmId == request.auth.uid;
    }

    // --- Lease templates (reusable by PM) ---
    match /leaseTemplates/{templateId} {
      allow read: if isSignedIn() && resource.data.pmId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.pmId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.pmId == request.auth.uid;
    }

    // --- Payment reviews (thumbs up/down per payment) ---
    match /paymentReviews/{paymentId} {
      allow read: if isSignedIn() &&
        (resource.data.tenantId == request.auth.uid ||
         resource.data.pmId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.tenantId == request.auth.uid;
      allow update: if isSignedIn() &&
        (resource.data.tenantId == request.auth.uid ||
         resource.data.pmId == request.auth.uid);
      allow delete: if false;
    }

    // --- Shared documents (PM + tenant can upload/read) ---
    match /sharedDocuments/{docId} {
      allow read: if isSignedIn() &&
        (resource.data.tenantId == request.auth.uid ||
         resource.data.pmId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.uploaderId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uploaderId == request.auth.uid;
      allow update: if false;
    }
  }
}
